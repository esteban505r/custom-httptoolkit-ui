{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://httptoolkit.local/schemas/api-registry-1.0.json",
  "title": "HTTP Toolkit API registry (.api.json)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "environments", "services"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "environments": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/service" }
    }
  },
  "$defs": {
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "team", "base_path", "status", "endpoints"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\s]+$"
        },
        "team": { "type": "string", "minLength": 1 },
        "base_path": {
          "type": "string",
          "pattern": "^/"
        },
        "openapi_url": { "type": "string", "format": "uri" },
        "status": {
          "type": "string",
          "enum": ["stable", "deprecated", "experimental"]
        },
        "endpoints": {
          "type": "array",
          "items": { "$ref": "#/$defs/endpoint" }
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "method", "path"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\s]+$"
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE",
            "HEAD",
            "OPTIONS"
          ]
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "sla_ms": { "type": "integer", "exclusiveMinimum": 0 }
      }
    }
  }
}
